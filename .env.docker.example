# ============================================================================
# IAM Policy Classifier - Docker Environment Configuration
# ============================================================================
# Copy this file to .env before running docker-compose up --build
# NOTE: ENVIRONMENT should be set to "production" when running via Docker
# ============================================================================

# ============================================================================
# Application Metadata
# ============================================================================
APP_NAME=IAM Policy Classifier
APP_VERSION=0.1.0
ENVIRONMENT=production

# ============================================================================
# LLM API Keys (AT LEAST ONE REQUIRED)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# LLM Configuration
# ============================================================================
DEFAULT_LLM_PROVIDER=claude
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o
LLM_TIMEOUT=30
MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# ============================================================================
# API Rate Limiting
# ============================================================================
API_RATE_LIMIT=10
RATE_LIMIT_WINDOW=60

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_JSON=true

# ============================================================================
# CORS Configuration
# ============================================================================
# In production, restrict to your actual frontend origin
CORS_ALLOWED_ORIGINS=http://localhost
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ============================================================================
# Security
# ============================================================================
ENABLE_API_AUTH=false
