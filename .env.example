# ============================================================================
# IAM Policy Classifier - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# At least one LLM API key (Anthropic or OpenAI) is required
# ============================================================================

# ============================================================================
# Application Metadata
# ============================================================================
APP_NAME=IAM Policy Classifier
APP_VERSION=0.1.0
ENVIRONMENT=development  # development, staging, or production

# ============================================================================
# LLM API Keys (AT LEAST ONE REQUIRED)
# ============================================================================
# Get your Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx

# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# LLM Configuration
# ============================================================================
# Default LLM provider to use (claude or openai)
DEFAULT_LLM_PROVIDER=claude

# Model names
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# LLM API timeout (seconds)
LLM_TIMEOUT=30

# Maximum tokens for LLM responses
MAX_TOKENS=1024

# Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# ============================================================================
# API Rate Limiting
# ============================================================================
# Maximum requests per minute
API_RATE_LIMIT=10

# Rate limit window (seconds)
RATE_LIMIT_WINDOW=60

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format string
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Optional: Log to file
# LOG_FILE=logs/app.log

# Enable JSON structured logging (true/false)
LOG_JSON=false

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow credentials in CORS (true/false)
CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods (comma-separated)
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers (comma-separated, or * for all)
CORS_ALLOWED_HEADERS=*

# ============================================================================
# Security (Future Use)
# ============================================================================
# Secret key for session management (generate with: openssl rand -hex 32)
# SECRET_KEY=your-secret-key-here

# Enable API key authentication (true/false)
ENABLE_API_AUTH=false

# ============================================================================
# Database Configuration (Future Use - Optional)
# ============================================================================
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/iam_classifier
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Database connection pool size
DB_POOL_SIZE=5

# Database connection timeout (seconds)
DB_TIMEOUT=10

# ============================================================================
# Redis Configuration (Future Use - Optional)
# ============================================================================
# Redis connection string
# Example: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# Redis cache TTL (seconds)
CACHE_TTL=3600

# ============================================================================
# Notes
# ============================================================================
# - Environment variables override values in this file
# - Boolean values: true/false (case-insensitive)
# - Lists: comma-separated values (no spaces)
# - Never commit your actual .env file with real API keys to git!
# ============================================================================
